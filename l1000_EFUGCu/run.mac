# EFCu holder-plate contamination in LEGEND-1000 geometry.
# Th-232 + U-238 decay chains (50/50), uniform in the copper weldment plates
# that hold each HPGe detector unit (1008 physvols).
# All 336 Ge detectors are read out (registered from the GDML <userinfo>).
/RMG/Geometry/RegisterDetectorsFromGDML Germanium
/run/initialize

# primaries uniformly distributed in the holder-plate bulk
/RMG/Generator/Confine Volume
/RMG/Generator/Confinement/Physical/AddVolume hpge_support_copper_weldment_top_.*

# ion at rest -> Geant4 radioactive decay handles the chains
/RMG/Generator/Select GPS

# source 0: Th-232
/gps/source/intensity 1
/gps/particle ion
/gps/ion 90 232
/gps/energy 0 eV

# source 1: U-238
/gps/source/add 1
/gps/particle ion
/gps/ion 92 238
/gps/energy 0 eV

# widen chain segment to cover both (U-238 has the larger A,Z bounds)
/process/had/rdm/nucleusLimits 1 238 1 92

/run/beamOn 200000
