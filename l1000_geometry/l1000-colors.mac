# LEGEND-1000 colours.
# /vis/geometry/set/colour <logical-volume> <depth> R G B alpha

# ═══════════════════════════════════════════════════════════
# STEEL CRYOSTAT + SUPPORTS (OUTERMOST)   —   alpha = 0.12 (inner cryostat 0.18)
# ═══════════════════════════════════════════════════════════
# --- steel cryostat/supports  (5 vol)  rgb=0.55 0.57 0.60
/vis/geometry/set/colour foot 0 0.55 0.57 0.6 1
/vis/geometry/set/colour innercryostat 0 0.55 0.57 0.6 1
/vis/geometry/set/colour outercryostat 0 0.55 0.57 0.6 1
/vis/geometry/set/colour skirt 0 0.55 0.57 0.6 1
# RT upper section (SS 316L, z 2857..4919) — cooler blue-grey than cryostat steel
/vis/geometry/set/colour ss_316l 0 0.50 0.56 0.66 1

# ═══════════════════════════════════════════════════════════
# CRYOSTAT VACUUM GAP   —   alpha = 0.15
# ═══════════════════════════════════════════════════════════
# --- vacuum gap  (1 vol)  rgb=0.55 0.55 0.62
/vis/geometry/set/colour vacuumgap 0 0.55 0.55 0.62 1

# ═══════════════════════════════════════════════════════════
# ATMOSPHERIC LAR (OUTER BATH)   —   alpha = 0.22
# ═══════════════════════════════════════════════════════════
# --- atmospheric LAr  (1 vol)  rgb=0.55 0.80 1.00
/vis/geometry/set/colour atmosphericlar 0 0.55 0.8 1 1

# ═══════════════════════════════════════════════════════════
# NEUTRON MODERATOR   —   alpha = 0.26
# ═══════════════════════════════════════════════════════════
# --- neutron moderator  (1 vol)  rgb=0.65 0.55 0.30
/vis/geometry/set/colour neutronmoderator 0 0.65 0.55 0.3 1

# ═══════════════════════════════════════════════════════════
# OUTER WLS SHROUD   —   alpha = 0.30
# ═══════════════════════════════════════════════════════════
# --- outer WLS shroud  (2 vol)  rgb=0.96 0.96 0.96
/vis/geometry/set/colour wls_tetratex_outer_atmospheric_lv 0 0.96 0.96 0.96 1
/vis/geometry/set/colour wls_tpb_outer_atmospheric_lv 0 0.6 0.9 1 1

# ═══════════════════════════════════════════════════════════
# COPPER REENTRANT TUBE   —   alpha = 0.35
# ═══════════════════════════════════════════════════════════
# --- reentrant tube (Cu)  (1 vol)  rgb=0.85 0.45 0.12
# RT lower section + endcap (EFCu mother, exposed z -1327..852) — bright copper
/vis/geometry/set/colour reentrancetube 0 0.85 0.45 0.12 1

# ═══════════════════════════════════════════════════════════
# UNDERGROUND LAR (INNER ACTIVE BATH)   —   alpha = 0.40
# ═══════════════════════════════════════════════════════════
# --- underground LAr  (1 vol)  rgb=0.55 0.80 1.00
/vis/geometry/set/colour undergroundlar 0 0.55 0.8 1 1

# ═══════════════════════════════════════════════════════════
# INNER WLS SHROUD   —   alpha = 0.45
# ═══════════════════════════════════════════════════════════
# --- inner WLS shroud  (2 vol)  rgb=0.96 0.96 0.96
/vis/geometry/set/colour wls_tetratex_inner_argon_lv 0 0.96 0.96 0.96 1
/vis/geometry/set/colour wls_tpb_inner_argon_lv 0 0.6 0.9 1 1

# ═══════════════════════════════════════════════════════════
# WLS FIBRES   —   alpha = 0.50
# ═══════════════════════════════════════════════════════════
# --- WLS fibres  (4 vol)  rgb=0.40 0.90 0.45
/vis/geometry/set/colour fiber_cl1_l1349_bNone 0 0.4 0.9 0.45 1
/vis/geometry/set/colour fiber_cl2_l1349_bNone 0 0.4 0.9 0.45 1
/vis/geometry/set/colour fiber_coating_l1349_tpb1093 0 0.4 0.9 0.45 1
/vis/geometry/set/colour fiber_core_l1349_bNone 0 0.4 0.9 0.45 1

# ═══════════════════════════════════════════════════════════
# STRING HARDWARE   —   alpha graded by peel depth: Cu 0.60, ultem 0.66, PEN 0.72, ASIC 0.80, SiPM 0.88
# ═══════════════════════════════════════════════════════════
# --- PEN holders  (2 vol)  rgb=0.95 0.80 0.28
/vis/geometry/set/colour hpge_support_copper_tristar_xlarge 0 0.95 0.8 0.28 1
/vis/geometry/set/colour pen_xlarge 0 0.95 0.8 0.28 1

