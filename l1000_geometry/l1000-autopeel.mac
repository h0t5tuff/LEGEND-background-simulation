# ══════════════════════════════════════════════════════════════════════════
#  L1000 AUTOMATIC PEEL — self-contained (no toggles/fade*, peelstep, fadenext)
#
#  Run:  remage -i l1000-vis.mac    then at Idle>:  /control/execute l1000-autopeel.mac
#
#  Culls the 15 radial layers outer -> inner, >=3 s dwell each, ending on bare
#  336 HPGe. Dwell = /vis/viewer/interpolate over interpolation/*.g4view (this
#  Geant4 has no /control/sleep); wait-time is an enforced minimum, so
#  10 x 300 ms = 3 s/layer. Transitions are instant visibility culls.
#  TIMING KNOB = the two numbers on each interpolate line.
#  RESET afterwards:  /vis/geometry/set/visibility world -1 true
# ══════════════════════════════════════════════════════════════════════════

# ── FADE 1/15 (hide/cull): outer steel + supports (3 vols).
/vis/viewer/interpolate interpolation 10 300 millisecond
/vis/geometry/set/visibility foot 0 false
/vis/geometry/set/visibility outercryostat 0 false
/vis/geometry/set/visibility skirt 0 false

# ── FADE 2/15 (hide/cull): vacuum gap (1 vols).
/vis/viewer/interpolate interpolation 10 300 millisecond
/vis/geometry/set/visibility vacuumgap 0 false

# ── FADE 3/15 (hide/cull): inner cryostat (1 vols).
/vis/viewer/interpolate interpolation 10 300 millisecond
/vis/geometry/set/visibility innercryostat 0 false

# ── FADE 4/15 (hide/cull): atmospheric LAr (outer bath) (1 vols).
/vis/viewer/interpolate interpolation 10 300 millisecond
/vis/geometry/set/visibility atmosphericlar 0 false

# ── FADE 5/15 (hide/cull): neutron moderator (1 vols).
/vis/viewer/interpolate interpolation 10 300 millisecond
/vis/geometry/set/visibility neutronmoderator 0 false

# ── FADE 6/15 (hide/cull): outer WLS shroud (2 vols).
/vis/viewer/interpolate interpolation 10 300 millisecond
/vis/geometry/set/visibility wls_tetratex_outer_atmospheric_lv 0 false
/vis/geometry/set/visibility wls_tpb_outer_atmospheric_lv 0 false

# ── FADE 7/15 (hide/cull): reentrant-tube wall stack (3 vols):
#    EFCu mother (z -1327..852) + ofhc_cu (852..2857) + ss_316l (2857..4919).
#    NB ofhc_cu & ss_316l are DAUGHTERS inside reentrancetube — hiding the
#    mother does not hide them, so all three must be culled here together.
/vis/viewer/interpolate interpolation 10 300 millisecond
/vis/geometry/set/visibility reentrancetube 0 false
/vis/geometry/set/visibility ofhc_cu 0 false
/vis/geometry/set/visibility ss_316l 0 false

# ── FADE 8/15 (hide/cull): underground LAr (inner bath) (1 vols).
/vis/viewer/interpolate interpolation 10 300 millisecond
/vis/geometry/set/visibility undergroundlar 0 false

# ── FADE 9/15 (hide/cull): inner WLS shroud (2 vols).
/vis/viewer/interpolate interpolation 10 300 millisecond
/vis/geometry/set/visibility wls_tetratex_inner_argon_lv 0 false
/vis/geometry/set/visibility wls_tpb_inner_argon_lv 0 false

# ── FADE 10/15 (hide/cull): WLS fibres (4 vols).
/vis/viewer/interpolate interpolation 10 300 millisecond
/vis/geometry/set/visibility fiber_cl1_l1349_bNone 0 false
/vis/geometry/set/visibility fiber_cl2_l1349_bNone 0 false
/vis/geometry/set/visibility fiber_coating_l1349_tpb1093 0 false
/vis/geometry/set/visibility fiber_core_l1349_bNone 0 false

# ── FADE 11/15 (hide/cull): copper string structure (1053 vols).
/vis/viewer/interpolate interpolation 10 300 millisecond
/vis/geometry/set/visibility cable_hv_V0101 0 false
/vis/geometry/set/visibility cable_hv_V0102 0 false
/vis/geometry/set/visibility cable_hv_V0103 0 false
/vis/geometry/set/visibility cable_hv_V0104 0 false
/vis/geometry/set/visibility cable_hv_V0105 0 false
