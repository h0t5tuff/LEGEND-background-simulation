# LEGEND-200 colours with DEPTH-GRADED opacity.
# Outer shells are lightly see-through; opacity rises layer by layer toward
# the HPGe detectors at the centre. Every component stays visible.
# /vis/geometry/set/colour <logical-volume> <depth> R G B alpha

# ═══════════════════════════════════════════════════════════
# ARGON BATH (MEDIUM)   —   alpha = 0.15
# ═══════════════════════════════════════════════════════════
# --- liquid argon  (1 vol)  rgb=0.55 0.80 1.00
/vis/geometry/set/colour liquid_argon 0 0.55 0.8 1 0.15

# --- gaseous argon  (1 vol)  rgb=0.70 0.88 1.00
/vis/geometry/set/colour gaseous_argon 0 0.7 0.88 1 0.15

# ═══════════════════════════════════════════════════════════
# CRYOSTAT STEEL (OUTER SHELL)   —   alpha = 0.12
# ═══════════════════════════════════════════════════════════
# --- cryostat steel  (1 vol)  rgb=0.55 0.57 0.60
/vis/geometry/set/colour cryostat_steel 0 0.55 0.57 0.6 0.12

# ═══════════════════════════════════════════════════════════
# WLSR REFLECTOR BARREL   —   alpha = 0.28
# ═══════════════════════════════════════════════════════════
# --- WLSR copper  (1 vol)  rgb=0.85 0.45 0.12
/vis/geometry/set/colour wlsr_copper 0 0.85 0.45 0.12 0.28

# --- WLSR tetratex  (1 vol)  rgb=0.96 0.96 0.96
/vis/geometry/set/colour wlsr_tetratex 0 0.96 0.96 0.96 0.28

# --- WLSR TPB  (1 vol)  rgb=0.60 0.90 1.00
/vis/geometry/set/colour wlsr_tpb 0 0.6 0.9 1 0.28

